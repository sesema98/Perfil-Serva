      .bar-track {
        width: 100%;
        height: 10px;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.09);
        overflow: hidden;
      }

      .bar-fill {
        width: 0;
        height: 100%;
        border-radius: inherit;
        background: linear-gradient(90deg, var(--teal), var(--accent));
        transition: width 700ms cubic-bezier(0.2, 1, 0.22, 1);
      }

      .projects-list {
        display: grid;
        gap: 14px;
      }

      .project-card {
        padding: 18px;
        display: grid;
        gap: 10px;
      }

      .project-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        flex-wrap: wrap;
