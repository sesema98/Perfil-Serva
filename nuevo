      const techGrid = document.querySelector("#tech-grid");
      const projectsList = document.querySelector("#projects-list");
      const tabButtons = document.querySelectorAll(".tab-button");
      const panels = document.querySelectorAll(".panel");

      function toDateValue(value) {
        return value ? new Date(value).getTime() : 0;
      }

      function normalizeRepos(repos) {
        return repos.filter((repo) => !repo.fork && repo.name !== GITHUB_USER);
      }

      function getLanguageStats(repos, fallbackStats) {
        const counts = new Map();

        repos.forEach((repo) => {
          if (!repo.language) return;
          counts.set(repo.language, (counts.get(repo.language) || 0) + 1);
        });

        const computed = Array.from(counts.entries())
          .map(([language, count]) => ({ language, count }))
          .sort((left, right) => right.count - left.count);

        return computed.length ? computed : fallbackStats;
      }

      function getFeaturedRepos(repos) {
        const repoMap = new Map(repos.map((repo) => [repo.name, repo]));
        const selected = [];

        PREFERRED_PROJECTS.forEach((name) => {
          const repo = repoMap.get(name);
          if (repo && !selected.find((item) => item.name === repo.name)) {
            selected.push(repo);
          }
        });

        return selected.slice(0, 3);
      }

      function getRepoDescription(repo) {
        if (repo.description && repo.description.trim()) {
          return repo.description.trim();
        }

        if (repo.language === "Kotlin" || repo.language === "Swift") {
          return `Proyecto de practica enfocado en desarrollo movil con ${repo.language}.`;
        }

        if (repo.language === "JavaScript" || repo.language === "TypeScript" || repo.language === "HTML") {
          return `Proyecto orientado a interfaces o experiencias web con ${repo.language}.`;
        }

        if (repo.language === "Java" || repo.language === "Python") {
          return `Proyecto donde trabajo logica, servicios o resolucion tecnica con ${repo.language}.`;
        }

        return "Parte de mi proceso de aprendizaje y practica.";
      }

      function renderMiniMeta(user, repos, languages) {
        const items = [
          `${user.public_repos || repos.length} repos`,
          `GitHub desde ${new Date(user.created_at).getFullYear()}`,
          `${languages.slice(0, 3).map((item) => item.language).join(" / ")}`,
        ];

        miniMeta.replaceChildren(
          ...items.map((text) => {
            const span = document.createElement("span");
            span.className = "mini-pill";
            span.textContent = text;
            return span;
          })
        );
      }

      function renderTechGrid(languages) {
        const maxCount = Math.max(...languages.map((item) => item.count), 1);

        techGrid.replaceChildren(
          ...languages.slice(0, 4).map((item) => {
            const card = document.createElement("article");
            card.className = "tech-card";

            const head = document.createElement("div");
            head.className = "tech-head";

            const title = document.createElement("strong");
            title.textContent = item.language;

            const count = document.createElement("span");
            count.textContent = `${item.count} repos`;

            head.append(title, count);

            const track = document.createElement("div");
            track.className = "bar-track";

            const fill = document.createElement("div");
            fill.className = "bar-fill";
            fill.dataset.width = `${Math.max(14, (item.count / maxCount) * 100)}%`;

            track.append(fill);
            card.append(head, track);
            return card;
          })
        );

        requestAnimationFrame(() => {
          document.querySelectorAll(".bar-fill").forEach((fill) => {
            fill.style.width = fill.dataset.width;
          });
        });
      }

      function renderProjects(repos) {
        projectsList.replaceChildren(
          ...repos.map((repo) => {
            const card = document.createElement("article");
            card.className = "project-card";

            const top = document.createElement("div");
            top.className = "project-top";

            const label = document.createElement("span");
            label.className = "project-label";
            label.textContent = repo.language || "Proyecto";

            const date = document.createElement("span");
            date.className = "project-date";
            date.textContent = shortDate.format(new Date(repo.pushed_at));

            top.append(label, date);

            const title = document.createElement("h3");
            title.textContent = repo.name;

            const copy = document.createElement("p");
            copy.textContent = getRepoDescription(repo);

            const link = document.createElement("a");
            link.href = repo.html_url;
            link.target = "_blank";
            link.rel = "noreferrer";
            link.textContent = "Ver proyecto";

            card.append(top, title, copy, link);
            return card;
          })
        );
      }

      function activateTab(tabId) {
        tabButtons.forEach((button) => {
          const isActive = button.dataset.tab === tabId;
          button.classList.toggle("is-active", isActive);
          button.setAttribute("aria-selected", String(isActive));
        });

        panels.forEach((panel) => {
          panel.classList.toggle("is-active", panel.id === `panel-${tabId}`);
        });

        history.replaceState(null, "", `#${tabId}`);
      }

      async function loadProfile() {
        try {
          const [userResponse, reposResponse] = await Promise.all([
            fetch(`https://api.github.com/users/${GITHUB_USER}`),
            fetch(`https://api.github.com/users/${GITHUB_USER}/repos?per_page=100&sort=updated`),
          ]);

          if (!userResponse.ok || !reposResponse.ok) {
            throw new Error("GitHub unavailable");
          }

          const [user, repos] = await Promise.all([userResponse.json(), reposResponse.json()]);
          const safeRepos = normalizeRepos(repos);
          const languages = getLanguageStats(safeRepos, fallbackData.languageSummary);

          avatar.src = user.avatar_url || fallbackData.user.avatar_url;
          renderMiniMeta(user, safeRepos, languages);
          renderTechGrid(languages);
          renderProjects(getFeaturedRepos(safeRepos));
          dataNote.textContent = `Esta vista se apoya en mis proyectos publicos de GitHub y muestra informacion reciente hasta ${monthYear.format(new Date(Math.max(...safeRepos.map((repo) => toDateValue(repo.pushed_at)))))}.`;
        } catch (error) {
          const safeRepos = normalizeRepos(fallbackData.repos);
          const languages = getLanguageStats(safeRepos, fallbackData.languageSummary);

          avatar.src = fallbackData.user.avatar_url;
          renderMiniMeta(fallbackData.user, safeRepos, languages);
          renderTechGrid(languages);
          renderProjects(getFeaturedRepos(safeRepos));
          dataNote.textContent = `Esta vista usa una copia reciente de mi perfil publico, actualizada el ${monthYear.format(new Date(`${SNAPSHOT_DATE}T00:00:00`))}.`;
        }
      }

      tabButtons.forEach((button) => {
        button.addEventListener("click", () => activateTab(button.dataset.tab));
      });

      const initialTab = location.hash.replace("#", "");
      activateTab(["about", "stack", "projects", "links"].includes(initialTab) ? initialTab : "about");
      loadProfile();
    </script>
  </body>
</html>
