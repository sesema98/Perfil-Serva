        line-height: 0.94;
        max-width: 10ch;
      }

      .role {
        margin: 14px 0 0;
        color: var(--text);
        font-size: 1.02rem;
        line-height: 1.7;
        max-width: 55ch;
      }

      .mini-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-top: 18px;
      }

      .mini-pill {
        padding: 10px 14px;
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.05);
        color: var(--text);
        font-size: 0.9rem;
      }

      .data-note {
        margin-top: 16px;
        color: var(--muted);
        font-size: 0.92rem;
        line-height: 1.7;
      }

      .tabs {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        padding: 20px 28px 0;
      }

      .tab-button {
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.04);
        color: var(--muted);
        padding: 10px 16px;
        cursor: pointer;
        transition:
          transform 160ms ease,
          background-color 160ms ease,
          color 160ms ease,
          border-color 160ms ease;
      }

      .tab-button:hover,
      .tab-button:focus-visible {
        transform: translateY(-1px);
        color: var(--text);
        border-color: rgba(255, 255, 255, 0.18);
        outline: none;
      }

      .tab-button.is-active {
        background: var(--accent-soft);
        color: var(--text);
        border-color: rgba(242, 154, 92, 0.3);
      }

      .panel-shell {
        padding: 22px 28px 28px;
      }

      .panel {
        display: none;
        min-height: 290px;
        animation: fadeIn 220ms ease;
      }

      .panel.is-active {
        display: grid;
        align-content: start;
        gap: 18px;
      }

      @keyframes fadeIn {
        from {
          opacity: 0;
          transform: translateY(8px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      .panel-copy {
        margin: 0;
        color: var(--muted);
        line-height: 1.8;
        max-width: 62ch;
      }

      .simple-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 14px;
      }

      .small-card,
      .project-card,
      .link-card,
      .tech-card {
        border: 1px solid rgba(255, 255, 255, 0.09);
