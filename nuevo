        width: fit-content;
      }

      .links-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 14px;
      }

      .link-card {
        padding: 18px;
        display: grid;
        gap: 12px;
        transition:
